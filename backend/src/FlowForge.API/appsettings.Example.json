{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=flowforge;Username=postgres;Password=YOUR_PASSWORD_HERE"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "YOUR_RABBITMQ_PASSWORD"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARS_LONG",
    "Issuer": "FlowForge",
    "Audience": "FlowForgeUsers",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "OpenAI": {
    "ApiKey": "sk-YOUR_OPENAI_API_KEY_HERE",
    "Model": "gpt-4o-mini"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "YOUR_MINIO_ACCESS_KEY",
    "SecretKey": "YOUR_MINIO_SECRET_KEY",
    "BucketName": "flowforge-files",
    "UseSSL": false
  },
  "Email": {
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "FromAddress": "noreply@flowforge.local",
    "FromName": "FlowForge"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4201"
    ]
  },
  "AllowedHosts": "*"
}
